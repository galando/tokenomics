{
  "name": "tokenomics",
  "version": "1.4.0",
  "description": "Token intelligence for AI coding agents — analyze sessions, find waste, get actionable fixes. Supports Claude Code, Cursor, Copilot, and Codex.",
  "type": "module",
  "main": "dist/analyze.js",
  "bin": {
    "tokenomics": "./dist/analyze.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "prepare": "npm run build",
    "prepublishOnly": "npm run build && npm test"
  },
  "keywords": [
    "claude-code",
    "cursor",
    "copilot",
    "codex",
    "token-optimization",
    "multi-agent",
    "ai-agents",
    "cli",
    "developer-tools",
    "ai-tools"
  ],
  "author": "",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/galando/tokenomics"
  },
  "engines": {
    "node": ">=18"
  },
  "devDependencies": {
    "@types/node": "^22.13.10",
    "tsup": "^8.4.0",
    "typescript": "^5.8.2",
    "vitest": "^3.0.9"
  },
  "files": [
    "dist/"
  ]
}
